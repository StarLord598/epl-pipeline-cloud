%%{init: {'theme': 'dark', 'themeVariables': {'fontSize': '14px', 'primaryColor': '#38003c', 'lineColor': '#00ff85'}}}%%

flowchart TB
    subgraph SRC["🌐 Data Sources"]
        direction LR
        A1["⚽ football-data.org<br/><b>Live API</b>"]
        A2["📦 StatsBomb<br/><b>Historical</b>"]
    end

    subgraph CLOUD["☁️ AWS Cloud Platform"]
        direction TB
        subgraph ORCH["⚡ Orchestration"]
            E1["EventBridge<br/>Daily 6AM · 15min · Weekly"]
            E2["Step Functions<br/>Daily Pipeline"]
        end
        subgraph LAMBDA["λ Lambda Functions"]
            F1["daily_ingest<br/>StatsBomb → S3"]
            F2["live_matches<br/>football-data → S3<br/>(every 15 min)"]
            F3["backfill<br/>Season Backfill"]
            F4["data_quality<br/>Validation"]
            F5["api<br/>REST + Live Merge"]
        end
        subgraph LAKE["🪣 S3 Data Lake (Parquet)"]
            G1["raw/matches/"]
            G2["raw/live_matches/<br/>(date-partitioned)"]
            G3["raw/standings/"]
            G4["raw/top_scorers/"]
        end
        subgraph QUERY["🔍 Query & Catalog"]
            H1["Glue Catalog"]
            H2["Athena"]
        end
        subgraph API["🌍 Public API"]
            I1["API Gateway"]
            I2["CloudFront CDN<br/>5-min cache · HTTPS"]
        end
        subgraph MON["📡 Monitoring"]
            K1["CloudWatch<br/>Dashboard + 4 Alarms"]
            K2["SNS<br/>2 Notification Topics"]
        end
        subgraph SEC["🔐 Security"]
            SM["Secrets Manager<br/>API Keys"]
            IAM["IAM Roles<br/>Lambda · SFN · OIDC"]
        end
    end

    subgraph DASH["🖥️ Dashboard (Vercel)"]
        J1["Next.js 14<br/>12 pages"]
        J2["Static JSON<br/>Fallback"]
    end

    subgraph CICD["🔄 CI/CD"]
        L1["GitHub Actions<br/>OIDC Auth"]
        L2["Terraform IaC<br/>62 resources"]
    end

    %% Source → Lambda
    A1 --> F1 & F2 & F3
    A2 --> F1

    %% Orchestration
    E1 --> E2
    E1 --> F2 & F3
    E2 --> F1
    E2 --> F4
    E2 --> K2

    %% Lambda → S3
    F1 --> G1 & G3 & G4
    F2 --> G2
    F3 --> G1

    %% Secrets
    SM --> F1 & F2 & F3

    %% Quality
    F4 -->|validates| G1

    %% S3 → Query
    G1 & G2 & G3 & G4 --> H1
    H1 --> H2

    %% API flow — live merge
    I2 --> I1 --> F5
    F5 -->|"daily data"| G1
    F5 -->|"live scores (merged)"| G2
    F5 -->|reads| G3 & G4

    %% Dashboard → CloudFront
    J1 -->|"CloudFront API"| I2
    J1 -.->|"fallback"| J2

    %% Monitoring
    F1 & F2 & F3 --> K1
    K1 --> K2

    %% CI/CD
    L1 --> L2
    L1 -->|deploy| F1 & F2 & F3

    %% Styles
    style SRC fill:#0046A7,stroke:#00c8ff,color:#fff
    style CLOUD fill:#0d1117,stroke:#00ff85,color:#fff
    style DASH fill:#1a1a2e,stroke:#8e44ad,color:#fff
    style CICD fill:#38003c,stroke:#f97316,color:#fff
    style LAKE fill:#1a2332,stroke:#ff6b6b,color:#fff
    style LAMBDA fill:#1a2332,stroke:#ffd93d,color:#fff
    style QUERY fill:#1a2332,stroke:#00c8ff,color:#fff
    style API fill:#1a2332,stroke:#9b59b6,color:#fff
    style MON fill:#1a2332,stroke:#e67e22,color:#fff
    style SEC fill:#1a2332,stroke:#e74c3c,color:#fff
